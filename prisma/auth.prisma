model Credential {
    id         String   @id
    userId     String
    publicKey  Bytes
    counter    BigInt
    deviceType String
    backedUp   Boolean
    transports String[]
    createdAt  DateTime @default(now())
    user       User     @relation(fields: [userId], references: [id])
}

model Session {
    id        String   @id
    userId    String
    createdAt DateTime @default(now())
    expiredAt DateTime

    user User @relation(fields: [userId], references: [id])
}

model AuthCode {
    id                  String   @id @default(cuid())
    code                String   @unique @default(cuid())
    profileUrl          String
    clientId            String
    redirectUri         String
    scope               String?
    codeChallenge       String
    codeChallengeMethod String   @default("S256")
    used                Boolean  @default(false)
    expiresAt           DateTime
    createdAt           DateTime @default(now())
}

model Token {
    id         String   @id @default(cuid())
    token      String   @unique @default(cuid())
    profileUrl String
    clientId   String
    scope      String
    revoked    Boolean  @default(false)
    createdAt  DateTime @default(now())
}
